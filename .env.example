# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public app URL used for auth callback redirects in browser
# Example: https://moteis.bdsmbrazil.com.br
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps API Key (pour l'autocomplétion d'adresse)
# Obtenez votre clé sur: https://console.cloud.google.com/google/maps-apis
# Activez: Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# PayPal (assinatura mensal Premium)
# sandbox | live
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_PREMIUM_PLAN_ID=

