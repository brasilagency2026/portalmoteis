# ===========================================
# Configuration Cloudflare R2
# ===========================================
# Copiez ce fichier vers .env.local et remplissez les valeurs

# R2 Account ID (trouvé dans le dashboard Cloudflare)
R2_ACCOUNT_ID=votre_account_id_ici

# R2 Access Key ID (créé via R2 > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=votre_access_key_id_ici

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=votre_secret_access_key_ici

# Nom du bucket R2 (créez un bucket nommé "motel-photos")
R2_BUCKET_NAME=motel-photos

# URL publique du bucket R2 (format: https://pub-xxxxx.r2.dev)
R2_PUBLIC_URL=https://pub-votre-id.r2.dev

# ===========================================
# Configuration Supabase (source des images)
# ===========================================
SUPABASE_URL=https://npfrnhwwlbjwfcxewysq.supabase.co
SUPABASE_ANON_KEY=votre_supabase_anon_key
